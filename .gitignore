.mcp.json
logs/
eval_snapshots/
__pycache__/
*.pyc
.pytest_cache/
*.egg-info/
sim_results*.csv
game_log.md
.claude/*
# Track the training skill specifically (larger strategic framing lives here;
# /training skill reads it to frame results in project context). Everything
# else in .claude/ stays local (settings.json, permissions, other skills).
!.claude/skills/
.claude/skills/*
!.claude/skills/training/
alphazero_progress.json
alphazero_history.jsonl
alphazero_checkpoints/
training.log
sts2-solver/training*.log
sts2-solver/companion-api*.log
sts2-solver/overnight_benchmarks.log
sts2-solver/experiments/_watchdog/
.env
.env.local
supabase/.temp/
runs.db
runs.db-wal
runs.db-shm
onnx_models/
sts2-solver/tests/_test_onnx/
betaone_checkpoints/*
betaone_checkpoints_*/
betaone_checkpoint_*.pt
betaone_train.log
betaone_ppo_*/
betaone_v2.*/
*.onnx
*.pt
# Distillation datasets — pickled teacher rollouts, typically 100MB-500MB
# each. Regeneratable via scripts/distill_generate.py from a teacher
# checkpoint. Same for numpy arrays dumped by training/eval scripts.
*.pkl
*.npy
*.npz
# Production frontier checkpoint + vocab — kept in git so the runner works
# from a fresh clone without anyone re-running promote_to_frontier.py. The
# `!` rules must come AFTER the broad `*.pt` exclusion above (later gitignore
# patterns override earlier ones). Swap via `sts2-experiment promote <name> <gen>`.
!betaone_checkpoints/betaone_latest.pt
!betaone_checkpoints/card_vocab.json

# Experiments: track configs and templates, ignore data
!sts2-solver/experiments/_benchmark/**
!sts2-solver/experiments/_templates/**
!sts2-solver/experiments/*/config.yaml
